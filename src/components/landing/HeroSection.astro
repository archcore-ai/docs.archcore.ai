---
import PathChooserCard from '../PathChooserCard.astro';
import PathBadge from '../PathBadge.astro';
---

<section class="section hero">
	<div class="container-narrow hero__intro">
		<h1 class="hero__headline">
			Turn your repository into structured, machine-readable context.
		</h1>
		<p class="hero__subheadline">
			So AI agents can follow your architecture, rules, and decisions — instead of guessing.
		</p>
	</div>

	<div class="container hero__cards">
		<div class="hero__card hero__card--plugin">
			<div class="hero__card-badges">
				<PathBadge scope="plugin" />
				<PathBadge scope="dark" label="Recommended" />
			</div>
			<PathChooserCard
				scope="plugin"
				audience="For Claude Code and Cursor"
				title="Plugin"
				description="Higher-level workflows, guardrails, and intent commands inside your agent."
				href="/start/plugin-quick-start/"
				cta="Use the Plugin"
				emphasized
			/>
		</div>

		<div class="hero__card hero__card--cli">
			<div class="hero__card-badges">
				<PathBadge scope="cli" />
			</div>
			<PathChooserCard
				scope="cli"
				audience="For direct integrations"
				title="CLI"
				description="MCP server, session hooks, scripting, and agent hosts beyond the plugin."
				href="/cli/quick-start/"
				cta="Start with CLI"
			/>
		</div>
	</div>

	<p class="hero__proof container-narrow">
		Works with Claude Code, Cursor, GitHub Copilot, Gemini CLI, Codex CLI, and more.
	</p>
</section>

<style>
	.hero {
		text-align: center;
	}

	.hero__intro {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
		text-align: center;
		min-width: 0;
	}

	.hero__intro > * {
		max-width: 100%;
	}

	.hero__headline {
		margin: 0;
		max-width: 100%;
		font-size: 36px;
		line-height: 1.0;
		font-weight: 700;
		letter-spacing: -0.04em;
		color: var(--color-text);
		text-wrap: balance;
		overflow-wrap: break-word;
	}

	@media (min-width: 50rem) {
		.hero__headline {
			font-size: 56px;
			line-height: 0.96;
			letter-spacing: -0.045em;
		}
	}

	.hero__subheadline {
		margin: 0;
		max-width: 620px;
		font-size: 17px;
		line-height: 1.5;
		color: var(--color-text-secondary);
	}

	.hero__cards {
		display: grid;
		gap: 1rem;
		grid-template-columns: minmax(0, 1fr);
		margin-top: 3rem;
		text-align: left;
	}

	@media (min-width: 50rem) {
		.hero__cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.25rem;
		}
	}

	.hero__card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.hero__card-badges {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.hero__proof {
		margin-top: 2rem;
		font-size: 13px;
		color: var(--color-text-muted);
	}
</style>
