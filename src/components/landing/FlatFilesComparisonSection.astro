---
const cards = [
	{
		title: 'Describes what happened, not only what to do',
		description:
			'Decisions, rules, and specs carry the reasoning behind them, not just the instruction.',
	},
	{
		title: 'Relations connect decisions, rules, specs, and guides',
		description:
			'A graph of typed documents — not a single flat memo the agent has to re-read every turn.',
	},
	{
		title: 'Agents query typed documents through MCP',
		description:
			'The agent fetches exactly the document it needs by type, slug, or relation — no scrolling.',
	},
	{
		title: 'Context survives across tools and sessions',
		description:
			'.archcore/ ships with the repo. Same context for every agent, every teammate, every session.',
	},
];
---

<section class="section flat-files">
	<div class="container-narrow flat-files__intro">
		<h2 class="flat-files__headline">
			Why not just CLAUDE.md, AGENTS.md, or repository instructions?
		</h2>
		<p class="flat-files__lead">
			Instruction files are flat memory. Archcore is structured system context.
		</p>
		<p class="flat-files__supporting">
			Instruction files work for agent-specific prompts and short-lived rules. They are not a graph of decisions, standards, specs, and workflows.
		</p>
	</div>

	<div class="container">
		<div class="flat-files__grid">
			{cards.map((card) => (
				<article class="ff-card">
					<h3 class="ff-card__title">{card.title}</h3>
					<p class="ff-card__description">{card.description}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.flat-files__intro {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
		text-align: center;
		align-items: center;
		margin-bottom: 2.5rem;
	}

	.flat-files__headline {
		margin: 0;
		font-size: 28px;
		line-height: 1.08;
		font-weight: 700;
		letter-spacing: -0.035em;
		color: var(--color-text);
	}

	@media (min-width: 50rem) {
		.flat-files__headline {
			font-size: 34px;
			line-height: 1.05;
		}
	}

	.flat-files__lead {
		margin: 0;
		font-size: 17px;
		font-weight: 600;
		color: var(--color-text);
		max-width: 600px;
	}

	.flat-files__supporting {
		margin: 0;
		font-size: 14px;
		color: var(--color-text-secondary);
		line-height: 1.55;
		max-width: 600px;
	}

	.flat-files__grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 36rem) {
		.flat-files__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 64rem) {
		.flat-files__grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	.ff-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.25rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		box-shadow: 0 1px 0 rgba(17, 16, 14, 0.04);
	}

	.ff-card__title {
		margin: 0;
		font-size: 14px;
		font-weight: 700;
		line-height: 1.3;
		letter-spacing: -0.015em;
		color: var(--color-text);
	}

	.ff-card__description {
		margin: 0;
		font-size: 13px;
		color: var(--color-text-secondary);
		line-height: 1.55;
	}
</style>
