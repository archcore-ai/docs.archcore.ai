---
type Scope = 'plugin' | 'cli' | 'shared';

interface Props {
	scope: Scope;
	title: string;
	audience: string;
	description: string;
	href: string;
	cta?: string;
	emphasized?: boolean;
}

const { scope, title, audience, description, href, cta = 'Open', emphasized = false } = Astro.props;
---

<a
	href={href}
	class={`path-card path-card--${scope}${emphasized ? ' path-card--emphasized' : ''}`}
>
	<div class="path-card__audience">{audience}</div>
	<div class="path-card__title">{title}</div>
	<p class="path-card__description">{description}</p>
	<span class="path-card__cta">
		{cta} <span aria-hidden="true">&rarr;</span>
	</span>
</a>

<style>
	.path-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.5rem;
		border-radius: var(--radius-card);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		text-decoration: none;
		color: inherit;
		box-shadow: 0 1px 0 rgba(17, 16, 14, 0.04);
		transition: border-color 0.15s ease, background-color 0.15s ease;
	}

	.path-card:hover {
		border-color: var(--color-border-strong);
	}

	.path-card--emphasized {
		background: var(--color-elevated);
		border-color: var(--color-border-strong);
		box-shadow: 0 8px 24px rgba(17, 16, 14, 0.06);
	}

	.path-card--plugin {
		border-top: 3px solid var(--ac-path-plugin);
	}

	.path-card--cli {
		border-top: 3px solid var(--ac-path-cli);
	}

	.path-card--shared {
		border-top: 3px solid var(--ac-path-shared);
	}

	.path-card__audience {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--color-text-muted);
	}

	.path-card__title {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--color-text);
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	.path-card__description {
		margin: 0;
		color: var(--color-text-secondary);
		line-height: 1.55;
		font-size: 0.95rem;
	}

	.path-card__cta {
		margin-top: auto;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--color-action);
	}

	.path-card--plugin .path-card__cta {
		color: var(--ac-path-plugin);
	}

	.path-card--cli .path-card__cta {
		color: var(--ac-path-cli);
	}
</style>
