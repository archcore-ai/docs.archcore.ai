---
type Scope = 'plugin' | 'cli' | 'shared' | 'dark';

interface Props {
	scope: Scope;
	label?: string;
}

const { scope, label } = Astro.props;

const defaults: Record<Scope, string> = {
	plugin: 'Plugin',
	cli: 'CLI',
	shared: 'Shared',
	dark: 'Recommended',
};

const text = label ?? defaults[scope];
---

<span class={`path-badge path-badge--${scope}`}>{text}</span>

<style>
	.path-badge {
		display: inline-flex;
		align-items: center;
		padding: 3px 8px;
		border-radius: var(--radius-pill);
		font-size: 10px;
		font-weight: 600;
		line-height: 1;
		letter-spacing: -0.01em;
		text-transform: uppercase;
		border: 1px solid var(--color-border);
		background: var(--color-surface-muted);
		color: var(--color-text-secondary);
	}

	.path-badge--plugin {
		background: color-mix(in oklch, var(--ac-path-plugin) 14%, var(--color-surface));
		color: var(--ac-path-plugin);
		border-color: color-mix(in oklch, var(--ac-path-plugin) 35%, var(--color-border));
	}

	.path-badge--cli {
		background: color-mix(in oklch, var(--ac-path-cli) 12%, var(--color-surface));
		color: var(--ac-path-cli);
		border-color: color-mix(in oklch, var(--ac-path-cli) 30%, var(--color-border));
	}

	.path-badge--shared {
		background: var(--color-surface-muted);
		color: var(--color-text-secondary);
		border-color: var(--color-border);
	}

	.path-badge--dark {
		background: var(--color-action);
		color: var(--color-text-inverse);
		border-color: var(--color-action);
	}
</style>
